{
  "description": "Golden dataset for HK Accessible Transit Navigator evaluation. 30 representative queries covering all accessibility profiles, HK regions, and edge cases.",
  "version": "1.0",
  "test_cases": [
    {
      "case_id": "wheelchair_001",
      "input": "I need to go from Tai Po Market to Central. I use a wheelchair.",
      "profile": "wheelchair",
      "origin": "Tai Po Market",
      "destination": "Central",
      "expected_route_exists": true,
      "expected_modes": ["MTR"],
      "expected_constraints": ["step-free", "lift_at_both_stations"],
      "rubric": ["identifies_step_free_route", "checks_lift_status", "mentions_mtr_wide_gate"]
    },
    {
      "case_id": "wheelchair_002",
      "input": "from Sha Tin to Admiralty, wheelchair accessible please",
      "profile": "wheelchair",
      "origin": "Sha Tin",
      "destination": "Admiralty",
      "expected_route_exists": true,
      "expected_modes": ["MTR"],
      "expected_constraints": ["step-free", "lift_at_both_stations"],
      "rubric": ["identifies_step_free_route", "checks_lift_status", "mentions_interchange_accessibility"]
    },
    {
